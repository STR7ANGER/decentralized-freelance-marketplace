{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.next",
      "!**/dist",
      "!**/.local-ledger",
      "!**/target",
      "!**/.anchor"
    ]
  },
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2 },
  "linter": { "enabled": true, "rules": { "preset": "none" } },
  "javascript": {
    "formatter": { "quoteStyle": "double", "semicolons": "always" }
  }
}
